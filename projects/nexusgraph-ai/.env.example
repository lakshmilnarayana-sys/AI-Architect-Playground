# LLM Configuration
LLM_PROVIDER=openai  # 'openai', 'gemini', 'groq', or 'ollama'

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434  # Use http://ollama:11434 for Docker
OLLAMA_MODEL=llama3

# Neo4j Database
NEO4J_URI=bolt://localhost:7687  # Use bolt://neo4j:7687 for Docker
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=nexusgraph-local

# Streamlit
STREAMLIT_SERVER_PORT=8501
